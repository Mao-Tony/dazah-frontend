# ========================================
# 前端环境变量配置
# ========================================
# 复制此文件为 .env.local 并修改配置
# 本地开发可保持 localhost，服务器部署时改为实际地址

# 后端 API 地址（必填）
# 本地开发: http://localhost:8000/api/v1
# Docker 部署: http://backend:8000/api/v1
# 服务器部署: http://你的服务器IP:8000/api/v1 或 https://你的域名/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
